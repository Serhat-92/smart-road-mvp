{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-police-radar.local/schemas/speed-violation-alert.schema.json",
  "title": "SpeedViolationAlert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "event_id",
    "source_service",
    "emitted_at",
    "timestamp",
    "camera_id",
    "severity",
    "matched",
    "confidence_score",
    "speed_limit",
    "estimated_speed",
    "fused_speed",
    "violation_amount",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "event_type": {
      "const": "speed.violation_alert"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_service": {
      "type": "string"
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "camera_id": {
      "type": "string"
    },
    "severity": {
      "enum": ["warning", "critical"]
    },
    "matched": {
      "type": "boolean"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "speed_limit": {
      "type": "number",
      "minimum": 0
    },
    "estimated_speed": {
      "type": "number",
      "minimum": 0
    },
    "radar_speed": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "fused_speed": {
      "type": "number",
      "minimum": 0
    },
    "violation_amount": {
      "type": "number",
      "minimum": 0
    },
    "track_id": {
      "type": ["integer", "null"]
    },
    "label": {
      "type": ["string", "null"]
    },
    "radar": {
      "oneOf": [
        { "$ref": "#/$defs/radarReading" },
        { "type": "null" }
      ]
    },
    "visual": {
      "oneOf": [
        { "$ref": "#/$defs/visualTrack" },
        { "type": "null" }
      ]
    },
    "image_evidence_path": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "boundingBox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x1",
        "y1",
        "x2",
        "y2"
      ],
      "properties": {
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" }
      }
    },
    "radarReading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "reading_id",
        "relative_speed",
        "absolute_speed",
        "signal_confidence"
      ],
      "properties": {
        "source": { "type": "string" },
        "reading_id": { "type": "string" },
        "relative_speed": { "type": "number" },
        "absolute_speed": { "type": "number" },
        "patrol_speed": { "type": "number" },
        "patrol_accel": { "type": "number" },
        "signal_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "timestamp_ms": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "visualTrack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "track_id": { "type": ["integer", "null"] },
        "label": { "type": ["string", "null"] },
        "speed": { "type": ["number", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "bounding_box": {
          "oneOf": [
            { "$ref": "#/$defs/boundingBox" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
