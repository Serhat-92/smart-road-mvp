{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-police-radar.local/schemas/detection-event.schema.json",
  "title": "DetectionEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "event_id",
    "source_service",
    "emitted_at",
    "frame",
    "detections",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "event_type": {
      "const": "detection.event"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_service": {
      "type": "string"
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "frame": {
      "$ref": "#/$defs/frameMetadata"
    },
    "detections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/detection"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "boundingBox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x1",
        "y1",
        "x2",
        "y2"
      ],
      "properties": {
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" }
      }
    },
    "frameMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "frame_index"
      ],
      "properties": {
        "source": { "type": "string" },
        "frame_index": { "type": "integer", "minimum": 0 },
        "timestamp_ms": { "type": ["number", "null"], "minimum": 0 },
        "source_fps": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "width": { "type": ["integer", "null"], "minimum": 1 },
        "height": { "type": ["integer", "null"], "minimum": 1 },
        "sampled_fps": { "type": ["number", "null"], "exclusiveMinimum": 0 }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "confidence",
        "bounding_box"
      ],
      "properties": {
        "label": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "bounding_box": { "$ref": "#/$defs/boundingBox" },
        "class_id": { "type": ["integer", "null"] },
        "track_id": { "type": ["integer", "null"] }
      }
    }
  }
}
