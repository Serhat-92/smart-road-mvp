DOCKER_BUILDKIT=0
COMPOSE_DOCKER_CLI_BUILD=0

POSTGRES_DB=gateway_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_ENABLED=true
POSTGRES_ECHO=false

REDIS_PORT=6379

GATEWAY_API_ENV=development
GATEWAY_API_PORT=8080
GATEWAY_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GATEWAY_API_SEED_DEMO_DATA=true

AI_INFERENCE_ENV=development
AI_INFERENCE_PORT=8090
AI_INFERENCE_MODEL_PATH=/app/yolov8n.pt
AI_INFERENCE_SPEED_FACTOR=36.0
AI_INFERENCE_LAZY_MODEL=true
AI_INFERENCE_GATEWAY_API_URL=http://gateway-api:8080
AI_INFERENCE_EVIDENCE_DIR=/app/datasets/evidence

COMMAND_CENTER_PORT=8000

OPERATOR_DASHBOARD_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_USE_MOCK_API=false
